---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

export interface Props {
	page: number;
}

export async function getStaticPaths() {
	const allPosts = await getCollection('blog');
	const postsPerPage = 5;
	const totalPages = Math.ceil(allPosts.length / postsPerPage);
	
	return Array.from({ length: totalPages - 1 }, (_, i) => ({
		params: { page: (i + 2).toString() },
		props: { page: i + 2 },
	}));
}

const { page } = Astro.props;
const postsPerPage = 5;

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const formatDate = (date: Date) => {
	const month = String(date.getMonth() + 1).padStart(2, '0');
	const day = String(date.getDate()).padStart(2, '0');
	return `${month}-${day}`;
};

const startIndex = (page - 1) * postsPerPage;
const endIndex = startIndex + postsPerPage;
const paginatedPosts = allPosts.slice(startIndex, endIndex);

const groupedPaginatedPosts = paginatedPosts.reduce((acc, post) => {
	const year = post.data.pubDate.getFullYear().toString();
	if (!acc[year]) {
		acc[year] = [];
	}
	acc[year].push(post);
	return acc;
}, {} as Record<string, typeof allPosts>);

const sortedYears = Object.keys(groupedPaginatedPosts).sort((a, b) => parseInt(b) - parseInt(a));

const totalPages = Math.ceil(allPosts.length / postsPerPage);
---

<!doctype html>
<html lang="en">
	<head>
		<script is:inline>
			(function() {
				const STORAGE_KEY = 'astro-theme';
				let theme = 'light';
				
				if (typeof localStorage !== 'undefined') {
					const stored = localStorage.getItem(STORAGE_KEY);
					if (stored) {
						theme = stored;
					} else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
						theme = 'dark';
					}
				}
				
				if (theme === 'dark') {
					document.documentElement.classList.add('dark');
					document.documentElement.style.backgroundColor = '#111827';
					
					const style = document.createElement('style');
					style.id = 'theme-preload-style';
					style.textContent = `
						header {
							background-color: rgba(17, 24, 39, 0.95) !important;
							border-bottom-color: rgb(75, 85, 99) !important;
						}
						h2 a {
							color: rgb(255, 255, 255) !important;
						}
						.nav-center a {
							color: #9ca3af !important;
						}
						.nav-btn {
							color: #9ca3af !important;
						}
					`;
					document.head.appendChild(style);
				}
			})();
		</script>
		<BaseHead title={`${SITE_TITLE} - Page ${page}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 720px;
			}
			.archive-container {
				line-height: 1.8;
			}
			.year-section {
				margin-bottom: 1.75rem;
			}
			.year-title {
				font-size: 1.125rem;
				font-weight: 700;
				margin: 0 0 1rem 0;
				color: rgb(var(--accent));
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}
			.year-title::before {
				content: '';
				width: 4px;
				height: 1.125rem;
				background: linear-gradient(180deg, var(--accent), #8b5cf6);
				border-radius: 2px;
			}
			.post-list {
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			.post-item {
				padding: 0.4rem 0;
				border-radius: 0.375rem;
				transition: background 0.2s ease;
			}
			.post-item:hover {
				background: rgba(59, 130, 246, 0.06);
			}
			.post-link {
				display: flex;
				align-items: baseline;
				gap: 1rem;
				text-decoration: none;
				color: rgb(var(--black));
				padding: 0.375rem 0.5rem;
				border-radius: 0.375rem;
				transition: color 0.2s ease;
			}
			.post-link:hover {
				color: rgb(var(--accent));
			}
			.post-date {
				font-size: 0.85rem;
				color: rgb(var(--gray));
				min-width: 80px;
				flex-shrink: 0;
			}
			.post-title {
				font-size: 0.95rem;
				margin: 0;
			}
			.post-tags {
				display: flex;
				gap: 0.375rem;
				flex-wrap: wrap;
				flex-shrink: 0;
			}
			.post-tag {
				font-size: 0.7rem;
				color: rgb(var(--gray));
				padding: 0.125rem 0.375rem;
				background: rgb(var(--gray-light));
				border-radius: 0.25rem;
			}
			.pagination {
				display: flex;
				justify-content: center;
				align-items: center;
				gap: 0.375rem;
				margin-top: 2.5rem;
				padding-top: 1.5rem;
				border-top: 1px solid rgba(var(--gray), 0.2);
			}
			.pagination-link {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-width: 2.5rem;
				height: 2.5rem;
				padding: 0 0.75rem;
				text-decoration: none;
				color: rgb(var(--gray));
				font-size: 0.9rem;
				border-radius: 0.5rem;
				transition: all 0.2s ease;
				background: transparent;
			}
			.pagination-link:hover {
				color: rgb(var(--accent));
				background: rgba(59, 130, 246, 0.1);
			}
			.pagination-link.active {
				color: white;
				font-weight: 600;
				background: linear-gradient(135deg, var(--accent), #2563eb);
				box-shadow: 0 2px 8px rgba(59, 130, 246, 0.3);
			}
			@media (max-width: 720px) {
				main {
					width: 100%;
					padding: 0 1rem;
				}
				.post-link {
					flex-direction: column;
					gap: 0.1rem;
				}
				.post-date {
					min-width: auto;
				}
			}

			.dark .year-title {
				color: var(--accent-light);
			}
			.dark .year-title::before {
				background: linear-gradient(180deg, var(--accent-light), #a78bfa);
			}
			.dark .post-link {
				color: rgb(var(--white));
				text-decoration: none;
			}
			.dark .post-link:hover {
				color: var(--accent-light);
				text-decoration: none;
			}
			.dark .post-item:hover {
				background: rgba(96, 165, 250, 0.08);
			}
			.dark .post-date {
				color: #9ca3af;
			}
			.dark .post-tag {
				color: #9ca3af;
				background: rgb(var(--gray-dark));
			}
			.dark .pagination {
				border-top-color: rgb(var(--gray));
			}
			.dark .pagination-link {
				color: #9ca3af;
			}
			.dark .pagination-link:hover {
				color: var(--accent-light);
				background: rgba(96, 165, 250, 0.15);
			}
			.dark .pagination-link.active {
				color: white;
				background: linear-gradient(135deg, var(--accent-light), #3b82f6);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				{
					sortedYears.map((year) => (
						<div class="year-section" id={`year-${year}`}>
							<h2 class="year-title">{year}</h2>
							<ul class="post-list">
								{
									groupedPaginatedPosts[year].map((post) => (
										<li class="post-item">
											<a href={`/blog/${post.id}/`} class="post-link">
												<span class="post-date">{formatDate(post.data.pubDate)}</span>
												<h3 class="post-title">{post.data.title}</h3>
												{post.data.tags && post.data.tags.length > 0 && (
													<div class="post-tags">
														{post.data.tags.slice(0, 3).map((tag) => (
															<span class="post-tag">#{tag}</span>
														))}
														{post.data.tags.length > 3 && (
															<span class="post-tag">...{post.data.tags.length - 3}</span>
														)}
													</div>
												)}
											</a>
										</li>
									))
								}
							</ul>
						</div>
					))
				}
				
				{totalPages > 1 && (
					<nav class="pagination">
						{page > 1 && (
							<a href={`/blog${page > 2 ? `/${page - 1}/` : '/'}`} class="pagination-link">
								← Previous
							</a>
						)}
						
						{Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
							<a
								href={`/blog${p > 1 ? `/${p}/` : '/'}`}
								class={`pagination-link ${p === page ? 'active' : ''}`}
							>
								{p}
							</a>
						))}
						
						{page < totalPages && (
							<a href={`/blog/${page + 1}/`} class="pagination-link">
								Next →
							</a>
						)}
					</nav>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>