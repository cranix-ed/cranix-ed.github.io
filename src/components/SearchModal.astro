---
const isDark = 'dark';
---

<site-search>
	<button
		data-open-modal
		disabled
		aria-label="Search articles"
		aria-keyshortcuts="Control+K"
	>
		<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<circle cx="11" cy="11" r="8"/>
			<path d="m21 21-4.35-4.35"/>
		</svg>
		<span class="search-label" aria-hidden="true">Search</span>
		<kbd class="search-shortcut" style="display: none;">
			<kbd>Ctrl</kbd><kbd>K</kbd>
		</kbd>
	</button>
	<dialog style="padding: 0" aria-label="Search">
		<div class="search-wrapper">
			<div class="search-box">
				<svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="11" cy="11" r="8"/>
					<path d="m21 21-4.35-4.35"/>
				</svg>
				<input type="text" class="search-input" placeholder="Search..." />
				<button class="search-clear-btn" style="display: none;">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="18" y1="6" x2="6" y2="18"/>
						<line x1="6" y1="6" x2="18" y2="18"/>
					</svg>
				</button>
			</div>
			<div class="search-results-area">
				<div class="results-count">Type to search...</div>
				<div class="results-container"></div>
				<div class="dev-hint" style="display: none;">
					<p>Search is available after building the project.</p>
					<p>Run <code>npm run build</code> to enable search.</p>
				</div>
			</div>
		</div>
	</dialog>
</site-search>

<script is:inline>
	(() => {
		const openBtn = document.querySelector('button[data-open-modal]');
		const shortcut = openBtn?.querySelector('.search-shortcut');
		if (!openBtn || !(shortcut instanceof HTMLElement)) return;
		const platformKey = shortcut.querySelector('kbd');
		if (platformKey && /(Mac|iPhone|iPod|iPad)/i.test(navigator.platform)) {
			platformKey.textContent = '⌘';
			openBtn.setAttribute('aria-keyshortcuts', 'Meta+K');
		}
		shortcut.style.display = '';
	})();
</script>

<script>
	class SiteSearch extends HTMLElement {
		constructor() {
			super();
			const openBtn = this.querySelector('button[data-open-modal]');
			const dialog = this.querySelector('dialog');
			const searchInput = this.querySelector('.search-input');
			const searchClear = this.querySelector('.search-clear-btn');
			const resultsCount = this.querySelector('.results-count');
			const resultsContainer = this.querySelector('.results-container');
			const devHint = this.querySelector('.dev-hint');
			
			let searchTimeout = null;
			let pagefindReady = false;
			let isLoading = false;

			const closeModal = () => {
				dialog.close();
				searchInput.value = '';
				searchClear.style.display = 'none';
				resultsCount.textContent = 'Type to search...';
				resultsContainer.innerHTML = '';
				devHint.style.display = 'none';
			};

			const onClick = (event) => {
				const isLink = event.target.closest('a');
				if (isLink || (document.body.contains(event.target) && !dialog.contains(event.target))) {
					closeModal();
				}
			};

			const openModal = (event) => {
				dialog.showModal();
				document.body.toggleAttribute('data-search-modal-open', true);
				searchInput.focus();
				event?.stopPropagation();
				window.addEventListener('click', onClick);
			};

			openBtn.addEventListener('click', openModal);
			openBtn.disabled = false;

			dialog.addEventListener('close', () => {
				document.body.toggleAttribute('data-search-modal-open', false);
				window.removeEventListener('click', onClick);
			});

			const loadPagefind = () => {
				return new Promise((resolve) => {
					if (pagefindReady) {
						resolve(true);
						return;
					}
					if (isLoading) {
						setTimeout(() => loadPagefind().then(resolve), 100);
						return;
					}

					isLoading = true;
					
					const script = document.createElement('script');
					script.src = `${window.location.origin}/pagefind/pagefind.js`;
					script.onload = () => {
						pagefindReady = true;
						isLoading = false;
						resolve(true);
					};
					script.onerror = () => {
						isLoading = false;
						resolve(false);
					};
					document.head.appendChild(script);
				});
			};

			searchInput.addEventListener('input', async (e) => {
				const query = e.target.value.trim();
				searchClear.style.display = query ? 'flex' : 'none';
				
				if (searchTimeout) clearTimeout(searchTimeout);
				
				if (!query) {
					resultsCount.textContent = 'Type to search...';
					resultsContainer.innerHTML = '';
					devHint.style.display = 'none';
					return;
				}

				searchTimeout = setTimeout(async () => {
					const success = await loadPagefind();
					if (!success) {
						resultsCount.textContent = 'Search unavailable';
						resultsContainer.innerHTML = '';
						devHint.style.display = 'block';
						return;
					}

					try {
						const results = await window.pagefind.search(query);
						displayResults(results, query);
					} catch (error) {
						resultsCount.textContent = 'Search unavailable';
						resultsContainer.innerHTML = '';
						devHint.style.display = 'block';
					}
				}, 150);
			});

			searchClear.addEventListener('click', () => {
				searchInput.value = '';
				searchClear.style.display = 'none';
				resultsCount.textContent = 'Type to search...';
				resultsContainer.innerHTML = '';
				devHint.style.display = 'none';
				searchInput.focus();
			});

			const displayResults = (results, query) => {
				if (!results || results.results.length === 0) {
					resultsCount.textContent = `No results for "${query}"`;
					resultsContainer.innerHTML = '';
					devHint.style.display = 'none';
					return;
				}

				resultsCount.textContent = `${results.results.length} results for "${query}"`;
				
				let html = '';
				for (const result of results.results) {
					const title = highlightText(result.meta.title || result.url.split('/').pop(), query);
					
					html += `
						<div class="result-card">
							<a href="${result.url}" class="result-main-link">${title}</a>
					`;
					
					if (result.subresults && result.subresults.length > 0) {
						for (const sub of result.subresults) {
							const subTitle = highlightText(sub.title, query);
							const subExcerpt = sub.excerpt ? highlightText(sub.excerpt, query) : '';
							html += `
								<div class="result-sub-item">
									<svg class="sub-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M18 8v6l-3-3M12 19h7l-7-7v7Z"/>
									</svg>
									<div class="sub-content">
										<a href="${result.url}#${sub.id}" class="sub-link">${subTitle}</a>
										${subExcerpt ? `<p class="sub-excerpt">${subExcerpt}</p>` : ''}
									</div>
								</div>
							`;
						}
					}
					
					html += '</div>';
				}
				
				resultsContainer.innerHTML = html;
				devHint.style.display = 'none';
			};

			const highlightText = (text, query) => {
				if (!text) return '';
				const regex = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
				return text.replace(regex, '<mark>$1</mark>');
			};

			window.addEventListener('keydown', (e) => {
				if ((e.metaKey === true || e.ctrlKey === true) && e.key === 'k') {
					dialog.open ? closeModal() : openModal();
					e.preventDefault();
				}
				
				if (e.key === 'Escape' && dialog.open) {
					closeModal();
				}
			});
		}
	}

	customElements.define('site-search', SiteSearch);
</script>

<style>
	site-search {
		display: contents;
	}

	button[data-open-modal] {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		border: 0;
		background-color: transparent;
		color: var(--text-muted);
		cursor: pointer;
		height: 2.5rem;
		font-size: 1rem;
		padding: 0 0.5rem;
	}

	@media (min-width: 50rem) {
		button[data-open-modal] {
			border: 1px solid var(--border-color);
			border-radius: 0.5rem;
			padding-inline-start: 0.75rem;
			padding-inline-end: 0.5rem;
			background-color: var(--bg-primary);
			color: var(--text-muted);
			font-size: 0.875rem;
			width: 100%;
			max-width: 22rem;
			transition: border-color 0.2s, color 0.2s;
		}

		button[data-open-modal]:hover {
			border-color: var(--text-muted);
			color: var(--text-primary);
		}

		button[data-open-modal] > :last-child {
			margin-inline-start: auto;
		}
	}

	.search-label {
		display: none;
	}

	@media (min-width: 50rem) {
		.search-label {
			display: inline;
		}
	}

	.search-shortcut {
		display: flex;
		gap: 0.25em;
	}

	.search-shortcut kbd {
		border-radius: 0.25rem;
		font-size: 0.625rem;
		padding-inline: 0.375rem;
		padding-block: 0.125rem;
		background-color: #f3f4f6;
		font-family: ui-monospace, SFMono-Regular, monospace;
		min-width: 1.125rem;
		text-align: center;
	}

	dialog {
		margin: 0;
		background-color: #f8fafc;
		border: none;
		width: 100%;
		max-width: 100%;
		height: 100%;
		max-height: 100%;
		box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
	}

	dialog[open] {
		display: flex;
	}

	dialog::backdrop {
		background-color: rgba(0, 0, 0, 0.8);
		-webkit-backdrop-filter: blur(8px);
		backdrop-filter: blur(8px);
	}

	.search-wrapper {
		display: flex;
		flex-direction: column;
		height: 100%;
		width: 100%;
	}

	.search-box {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 1rem;
		background-color: #ffffff;
		border-bottom: 1px solid #e2e8f0;
	}

	.search-icon {
		flex-shrink: 0;
		color: #94a3b8;
	}

	.search-input {
		flex: 1;
		font-size: 1rem;
		color: #1e293b;
		border: none;
		outline: none;
		background: transparent;
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
	}

	.search-input::placeholder {
		color: #94a3b8;
	}

	.search-clear-btn {
		flex-shrink: 0;
		display: none;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		color: #94a3b8;
		background: transparent;
		border: none;
		cursor: pointer;
		border-radius: 4px;
		transition: color 0.2s, background-color 0.2s;
	}

	.search-clear-btn:hover {
		color: #1e293b;
		background-color: #f1f5f9;
	}

	.search-results-area {
		flex: 1;
		overflow-y: auto;
		display: flex;
		flex-direction: column;
	}

	.results-count {
		font-size: 0.8125rem;
		color: #64748b;
		padding: 0.75rem 1rem;
		font-weight: 500;
	}

	.results-container {
		flex: 1;
		overflow-y: auto;
		padding-bottom: 1rem;
	}

	.result-card {
		border: 1px solid #e2e8f0;
		border-radius: 8px;
		margin: 0 1rem 0.25rem;
		overflow: hidden;
		background-color: #ffffff;
	}

	.result-main-link {
		display: block;
		padding: 0.75rem 1rem;
		font-weight: 600;
		font-size: 0.9375rem;
		color: #1e293b;
		text-decoration: none;
		background-color: #ffffff;
		border-bottom: 1px solid #e2e8f0;
		transition: background-color 0.2s;
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
	}

	.result-main-link:hover {
		background-color: #f8fafc;
	}

	.result-sub-item {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		padding: 0.625rem 1rem;
		border-bottom: 1px solid #f1f5f9;
		background-color: #fafafa;
		transition: background-color 0.2s;
	}

	.result-sub-item:last-child {
		border-bottom: none;
	}

	.result-sub-item:hover {
		background-color: #f1f5f9;
	}

	.sub-icon {
		flex-shrink: 0;
		color: #94a3b8;
		margin-top: 0.125rem;
	}

	.sub-content {
		flex: 1;
		min-width: 0;
	}

	.sub-link {
		display: block;
		font-weight: 500;
		font-size: 0.875rem;
		color: #475569;
		text-decoration: none;
		transition: color 0.2s;
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
	}

	.sub-link:hover {
		color: #2563eb;
	}

	.sub-excerpt {
		margin: 0.25rem 0 0;
		font-size: 0.8125rem;
		color: #64748b;
		line-height: 1.5;
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
	}

	.result-card mark {
		background-color: rgba(251, 191, 36, 0.4);
		color: #92400e;
		padding: 0 2px;
		border-radius: 2px;
	}

	.dev-hint {
		padding: 1rem;
		text-align: center;
		border-top: 1px solid #e2e8f0;
		background-color: #fef3c7;
	}

	.dev-hint p {
		margin: 0.25rem 0;
		font-size: 0.875rem;
		color: #92400e;
	}

	.dev-hint code {
		display: inline-block;
		padding: 0.125rem 0.375rem;
		background-color: rgba(0, 0, 0, 0.1);
		border-radius: 4px;
		font-family: ui-monospace, SFMono-Regular, monospace;
		font-size: 0.8125rem;
	}

	@media (min-width: 50rem) {
		dialog {
			margin: 4rem auto auto;
			border-radius: 12px;
			width: 90%;
			max-width: 52rem;
			height: max-content;
			min-height: 15rem;
			max-height: calc(100% - 8rem);
			animation: slideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		}

		@keyframes slideIn {
			from {
				opacity: 0;
				transform: translateY(-20px) scale(0.98);
			}
			to {
				opacity: 1;
				transform: translateY(0) scale(1);
			}
		}
	}

	html.dark .search-shortcut kbd {
		background-color: var(--bg-tertiary);
	}

	html.dark dialog {
		background-color: var(--bg-primary);
	}

	html.dark .search-wrapper {
		background-color: var(--bg-primary);
	}

	html.dark .search-box {
		background-color: var(--bg-secondary);
		border-bottom-color: var(--border-color);
	}

	html.dark .search-icon {
		color: var(--text-muted);
	}

	html.dark .search-input {
		color: var(--text-primary);
	}

	html.dark .search-input::placeholder {
		color: var(--text-muted);
	}

	html.dark .search-clear-btn {
		color: var(--text-muted);
	}

	html.dark .search-clear-btn:hover {
		color: var(--text-primary);
		background-color: var(--bg-tertiary);
	}

	html.dark .results-count {
		color: var(--text-muted);
	}

	html.dark .result-card {
		border-color: var(--border-color);
		background-color: var(--bg-secondary);
	}

	html.dark .result-main-link {
		color: var(--text-primary);
		background-color: var(--bg-secondary);
		border-bottom-color: var(--border-color);
	}

	html.dark .result-main-link:hover {
		background-color: var(--bg-tertiary);
	}

	html.dark .result-sub-item {
		background-color: var(--bg-tertiary);
		border-bottom-color: var(--border-color);
	}

	html.dark .result-sub-item:hover {
		background-color: rgba(59, 130, 246, 0.1);
	}

	html.dark .sub-icon {
		color: var(--text-muted);
	}

	html.dark .sub-link {
		color: var(--text-secondary);
	}

	html.dark .sub-link:hover {
		color: #60a5fa;
	}

	html.dark .sub-excerpt {
		color: var(--text-muted);
	}

	html.dark .result-card mark {
		background-color: rgba(251, 191, 36, 0.3);
		color: #fbbf24;
	}

	html.dark .dev-hint {
		background-color: rgba(251, 191, 36, 0.1);
		border-top-color: var(--border-color);
	}

	html.dark .dev-hint p {
		color: #fbbf24;
	}

	html.dark .dev-hint code {
		background-color: rgba(0, 0, 0, 0.2);
	}
</style>