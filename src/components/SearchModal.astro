---
const isDark = 'dark';
---

<site-search>
	<button
		data-open-modal
		disabled
		aria-label="Search articles"
		aria-keyshortcuts="Control+K"
	>
		<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<circle cx="11" cy="11" r="8"/>
			<path d="m21 21-4.35-4.35"/>
		</svg>
		<span class="search-label" aria-hidden="true">Search</span>
		<kbd class="search-shortcut" style="display: none;">
			<kbd>Ctrl</kbd><kbd>K</kbd>
		</kbd>
	</button>
	<dialog style="padding:0" aria-label="Search">
		<div class="dialog-frame">
			<button data-close-modal class="close-btn">
				Cancel
			</button>
			<div class="search-container">
				<form class="search-form" role="search">
					<svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="11" cy="11" r="8"/>
						<path d="m21 21-4.35-4.35"/>
					</svg>
					<input 
						type="text" 
						class="search-input" 
						placeholder="Search..." 
						autocomplete="off"
						spellcheck="false"
					/>
					<button type="button" class="search-clear" style="display: none;">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<line x1="18" y1="6" x2="6" y2="18"/>
							<line x1="6" y1="6" x2="18" y2="18"/>
						</svg>
					</button>
				</form>
				<div class="results-info" style="display: none;">
					<span class="results-count"></span> results for <mark class="search-term"></mark>
				</div>
				<div class="search-results">
					<div class="search-loading" style="display: none;">
						<div class="spinner"></div>
						<span>Loading...</span>
					</div>
					<div class="search-empty" style="display: none;">
						<p>No results found for "<span class="search-term"></span>"</p>
					</div>
					<div class="search-error" style="display: none;">
						<p>Search is unavailable. Please try again later.</p>
					</div>
					<ul class="results-list"></ul>
				</div>
			</div>
		</div>
	</dialog>
</site-search>

<script is:inline>
	(() => {
		const openBtn = document.querySelector('button[data-open-modal]');
		const shortcut = openBtn?.querySelector('.search-shortcut');
		if (!openBtn || !(shortcut instanceof HTMLElement)) return;
		const platformKey = shortcut.querySelector('kbd');
		if (platformKey && /(Mac|iPhone|iPod|iPad)/i.test(navigator.platform)) {
			platformKey.textContent = '⌘';
			openBtn.setAttribute('aria-keyshortcuts', 'Meta+K');
		}
		shortcut.style.display = '';
	})();
</script>

<script>
	class SiteSearch extends HTMLElement {
		constructor() {
			super();
			const openBtn = this.querySelector('button[data-open-modal]');
			const closeBtn = this.querySelector('button[data-close-modal]');
			const dialog = this.querySelector('dialog');
			const input = this.querySelector('.search-input');
			const clearBtn = this.querySelector('.search-clear');
			const resultsList = this.querySelector('.results-list');
			const loading = this.querySelector('.search-loading');
			const empty = this.querySelector('.search-empty');
			const error = this.querySelector('.search-error');
			const resultsInfo = this.querySelector('.results-info');
			const resultsCount = this.querySelector('.results-info .results-count');
			const searchTermElements = this.querySelectorAll('.search-term');

			let searchTimeout = null;
			let pagefindLoaded = false;
			let pagefindLoading = false;

			const loadPagefind = async () => {
				if (window.Pagefind) {
					pagefindLoaded = true;
					return;
				}
				if (pagefindLoading) {
					let attempts = 0;
					while (!window.Pagefind && attempts < 20) {
						await new Promise(r => setTimeout(r, 100));
						attempts++;
					}
					if (window.Pagefind) {
						pagefindLoaded = true;
					}
					return;
				}
				
				pagefindLoading = true;
				
				try {
					const module = await import('/pagefind/pagefind.js');
					window.Pagefind = {
						search: module.search,
						debouncedSearch: module.debouncedSearch,
						init: module.init
					};
					pagefindLoaded = true;
				} catch (err) {
					console.error('Failed to load Pagefind:', err);
					pagefindLoading = false;
				}
			};

			const closeModal = () => {
				if (dialog.open) {
					dialog.close();
					document.body.toggleAttribute('data-search-modal-open', false);
					input.value = '';
					clearBtn.style.display = 'none';
					resultsList.innerHTML = '';
					empty.style.display = 'none';
					error.style.display = 'none';
					resultsInfo.style.display = 'none';
				}
			};

			const showLoading = () => {
				loading.style.display = 'flex';
				empty.style.display = 'none';
				error.style.display = 'none';
				resultsInfo.style.display = 'none';
				resultsList.innerHTML = '';
			};

			const showResults = (results) => {
				loading.style.display = 'none';
				error.style.display = 'none';
				
				if (results.length === 0) {
					searchTermElements.forEach(el => el.textContent = input.value);
					empty.style.display = 'flex';
					resultsInfo.style.display = 'none';
					resultsList.innerHTML = '';
					return;
				}

				resultsCount.textContent = results.length;
				searchTermElements.forEach(el => el.textContent = input.value);
				resultsInfo.style.display = 'block';
				empty.style.display = 'none';
				resultsList.innerHTML = this.renderResults(results);
			};

			const showError = () => {
				loading.style.display = 'none';
				empty.style.display = 'none';
				resultsInfo.style.display = 'none';
				error.style.display = 'flex';
				resultsList.innerHTML = '';
			};

			const highlightText = (text, query) => {
				if (!text || !query) return text;
				const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
				const regex = new RegExp(`(${escaped})`, 'gi');
				return text.replace(regex, '<mark>$1</mark>');
			};

			const cleanText = (text) => {
				if (!text) return '';
				let clean = text.replace(/<[^>]*>/g, '');
				clean = clean.replace(/\s+/g, ' ').trim();
				return clean;
			};

			this.renderResults = (results) => {
				const isDark = document.documentElement.classList.contains('dark') || 
					document.body.classList.contains('dark') ||
					window.matchMedia('(prefers-color-scheme: dark)').matches;
				
				const bgColor = isDark ? '#1f2937' : '#ffffff';
				const borderColor = isDark ? '#374151' : '#e5e7eb';
				const hoverBorderColor = isDark ? '#4b5563' : '#d1d5db';
				const textColor = isDark ? '#e5e7eb' : '#1f2937';
				const mutedColor = isDark ? '#9ca3af' : '#6b7280';
				const iconColor = isDark ? '#9ca3af' : '#6b7280';
				const dateBg = isDark ? '#374151' : '#f3f4f6';
				const dateColor = isDark ? '#d1d5db' : '#9ca3af';
				const shadowColor = isDark ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.05)';
				const hoverShadowColor = isDark ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.1)';
				const borderLeftColor = isDark ? '#4b5563' : '#e5e7eb';
				
				return results.map(result => {
					const query = input.value.toLowerCase();
					let title = result.title;
					if (title.toLowerCase().includes(query)) {
						title = highlightText(result.title, input.value);
					} else {
						title = result.title;
					}
					
					const date = result.date || '';
					let excerpt = result.excerpt || '';
					if (excerpt) {
						if (excerpt.toLowerCase().includes(query)) {
							excerpt = highlightText(excerpt, input.value);
						}
					}
					
					return `
						<li style="background: ${bgColor}; border: 1px solid ${borderColor}; border-radius: 0.75rem; overflow: hidden; margin-bottom: 0.75rem; box-shadow: 0 1px 3px ${shadowColor}; transition: all 0.2s ease;" onmouseover="this.style.boxShadow='0 4px 12px ${hoverShadowColor}',this.style.borderColor='${hoverBorderColor}'" onmouseout="this.style.boxShadow='0 1px 3px ${shadowColor}',this.style.borderColor='${borderColor}'">
							<a href="${result.url}" style="display: block; padding: 1rem; text-decoration: none; color: inherit;">
								<div style="display: flex; align-items: flex-start; gap: 0.75rem;">
									<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="${iconColor}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0; margin-top: 0.125rem;">
										<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
										<polyline points="14 2 14 8 20 8"/>
										<line x1="16" y1="13" x2="8" y2="13"/>
										<line x1="16" y1="17" x2="8" y2="17"/>
										<polyline points="10 9 9 9 8 9"/>
									</svg>
									<div style="flex: 1; min-width: 0;">
										<div style="display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; flex-wrap: wrap;">
											<span style="font-weight: 600; color: ${textColor}; font-size: 0.95rem; line-height: 1.4;">${title}</span>
											${date ? `<span style="font-size: 0.7rem; color: ${dateColor}; font-family: ui-monospace, SFMono-Regular, monospace; white-space: nowrap; background: ${dateBg}; padding: 0.2rem 0.4rem; border-radius: 0.25rem;">${date}</span>` : ''}
										</div>
										${excerpt ? `<p style="margin: 0.5rem 0 0 0; padding: 0; font-size: 0.825rem; color: ${mutedColor}; line-height: 1.6; padding-left: 0.25rem; border-left: 3px solid ${borderLeftColor};">${excerpt}</p>` : ''}
									</div>
								</div>
							</a>
						</li>
					`;
				}).join('');
			};

			const performSearch = async (query) => {
				if (!query.trim()) {
					resultsList.innerHTML = '';
					loading.style.display = 'none';
					empty.style.display = 'none';
					error.style.display = 'none';
					resultsInfo.style.display = 'none';
					return;
				}

				showLoading();

				try {
					await loadPagefind();

					if (!window.Pagefind) {
						throw new Error('Pagefind not loaded');
					}

					const search = await window.Pagefind.search(query);
					const results = [];
					
					const urlMap = new Map();
					
					for (const result of search.results) {
						const data = await result.data();
						const pageUrl = data.url || '/';
						
						if (!pageUrl.startsWith('/blog/')) continue;
						if (urlMap.has(pageUrl)) continue;
						
						const urlParts = pageUrl.split('/').filter(p => p && p !== 'index.html' && p !== 'index');
						let pageTitle = urlParts[urlParts.length - 1] || 'Untitled';
						pageTitle = pageTitle.replace(/-/g, ' ').replace(/\.html?$/i, '').trim();
						
						let pageDate = '';
						if (data.meta?.date) {
							pageDate = data.meta.date;
						}
						
						let excerpt = '';
						if (data.excerpt && data.excerpt.length > 0) {
							excerpt = cleanText(data.excerpt);
							excerpt = excerpt.substring(0, 180) + (excerpt.length > 180 ? '...' : '');
						}
						
						urlMap.set(pageUrl, {
							url: pageUrl,
							title: pageTitle || 'Untitled',
							date: pageDate,
							excerpt: excerpt
						});
					}
					
					results.push(...urlMap.values());
					
					showResults(results);
				} catch (err) {
					console.error('Search error:', err);
					showError();
				}
			};

			const handleInput = () => {
				clearBtn.style.display = input.value ? 'flex' : 'none';
				
				if (searchTimeout) clearTimeout(searchTimeout);
				searchTimeout = setTimeout(() => {
					performSearch(input.value);
				}, 150);
			};

			const openModal = (event) => {
				dialog.showModal();
				document.body.toggleAttribute('data-search-modal-open', true);
				input.focus();
				event?.stopPropagation();
			};

			const handleKeydown = (event) => {
				if ((event.metaKey || event.ctrlKey) && event.key === 'k') {
					event.preventDefault();
					openModal();
				}
				if (event.key === 'Escape' && dialog.open) {
					closeModal();
				}
			};

			openBtn.removeAttribute('disabled');
			openBtn.addEventListener('click', openModal);
			closeBtn.addEventListener('click', closeModal);
			dialog.addEventListener('click', (e) => {
				if (e.target === dialog) {
					closeModal();
				}
			});
			input.addEventListener('input', handleInput);
			clearBtn.addEventListener('click', () => {
				input.value = '';
				clearBtn.style.display = 'none';
				resultsList.innerHTML = '';
				resultsInfo.style.display = 'none';
				input.focus();
			});
			document.addEventListener('keydown', handleKeydown);

			this.addEventListener('keydown', handleKeydown);
		}
	}

	customElements.define('site-search', SiteSearch);
</script>

<style>
	site-search {
		display: flex;
		align-items: center;
	}

	site-search > button {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 0.75rem;
		background-color: transparent;
		border: 1px solid var(--border-color);
		border-radius: 0.25rem;
		color: var(--text-secondary);
		font-size: 0.875rem;
		cursor: pointer;
		transition: background-color 0.15s ease;
	}

	site-search > button:hover {
		background-color: var(--bg-secondary);
		color: var(--text-primary);
	}

	.search-label {
		display: none;
	}

	@media (min-width: 640px) {
		.search-label {
			display: inline;
		}
	}

	.search-shortcut {
		display: flex;
		align-items: center;
		gap: 0.125rem;
		margin-left: 0.25rem;
	}

	.search-shortcut kbd {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 1.25rem;
		height: 1.25rem;
		padding: 0 0.25rem;
		font-size: 0.625rem;
		font-family: ui-monospace, SFMono-Regular, monospace;
		background-color: var(--bg-secondary);
		border: 1px solid var(--border-color);
		border-radius: 0.125rem;
	}

	dialog {
		width: 90vw;
		max-width: 48rem;
		border: none;
		border-radius: 0.5rem;
		background-color: var(--bg-primary);
		box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
	}

	dialog::backdrop {
		background-color: rgba(0, 0, 0, 0.5);
	}

	.dialog-frame {
		display: flex;
		flex-direction: column;
		height: 80vh;
	}

	.close-btn {
		align-self: flex-end;
		padding: 0.5rem 0.75rem;
		background-color: transparent;
		border: none;
		color: var(--text-muted);
		font-size: 0.75rem;
		cursor: pointer;
		transition: color 0.15s ease;
	}

	.close-btn:hover {
		color: var(--text-primary);
	}

	.search-container {
		display: flex;
		flex-direction: column;
		flex: 1;
		padding: 0 1rem 1rem;
	}

	.search-form {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 0.75rem;
		background-color: var(--bg-secondary);
		border: 1px solid var(--border-color);
		border-radius: 0.25rem;
	}

	.search-icon {
		color: var(--text-muted);
	}

	.search-input {
		flex: 1;
		background-color: transparent;
		border: none;
		outline: none;
		color: var(--text-primary);
		font-size: 0.875rem;
	}

	.search-input::placeholder {
		color: var(--text-muted);
	}

	.search-clear {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 1.5rem;
		height: 1.5rem;
		background-color: var(--accent);
		border: none;
		border-radius: 50%;
		color: white;
		cursor: pointer;
		transition: opacity 0.15s ease;
	}

	.search-clear:hover {
		opacity: 0.8;
	}

	.results-info {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		margin: 0.5rem 0;
		padding: 0.25rem 0;
		font-size: 0.75rem;
		color: var(--text-muted);
		border-bottom: 1px solid var(--border-color);
	}

	.results-info mark {
		background-color: var(--accent);
		color: white;
		padding: 0 0.125rem;
		border-radius: 0.125rem;
	}

	.search-results {
		flex: 1;
		overflow-y: auto;
	}

	.search-loading,
	.search-empty,
	.search-error {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 3rem 1rem;
		color: var(--text-muted);
	}

	.spinner {
		width: 32px;
		height: 32px;
		border: 2px solid var(--border-color);
		border-top-color: var(--accent);
		border-radius: 50%;
		animation: spin 0.8s linear infinite;
		margin-bottom: 0.75rem;
	}

	@keyframes spin {
		to { transform: rotate(360deg); }
	}

	.search-empty p,
	.search-error p {
		font-size: 0.875rem;
		text-align: center;
	}

	.search-empty .search-term {
		font-weight: 500;
		color: var(--text-primary);
	}

	.search-results .results-list {
		list-style: none !important;
		padding: 0 !important;
		margin: 0 !important;
		display: flex !important;
		flex-direction: column !important;
		gap: 0.75rem !important;
	}

	.search-results .search-result {
		background-color: rgba(0, 0, 0, 0.05) !important;
		border: 1px solid #e5e7eb !important;
		border-radius: 0.5rem !important;
		overflow: hidden !important;
	}

	.search-results .result-link {
		display: block !important;
		padding: 0.875rem !important;
		text-decoration: none !important;
		color: inherit !important;
		transition: background-color 0.15s ease !important;
	}

	.search-results .result-link:hover {
		background-color: rgba(0, 0, 0, 0.08) !important;
	}

	.search-results .result-header {
		display: flex !important;
		align-items: center !important;
		justify-content: space-between !important;
		gap: 0.75rem !important;
	}

	.search-results .result-title {
		font-weight: 600 !important;
		color: #1f2937 !important;
		font-size: 0.9rem !important;
	}

	.search-results .result-date {
		font-size: 0.7rem !important;
		color: #9ca3af !important;
		font-family: ui-monospace, SFMono-Regular, monospace !important;
		white-space: nowrap !important;
	}

	.search-results .result-excerpt {
		margin: 0.75rem 0 0 1.75rem !important;
		padding: 0 !important;
		font-size: 0.8rem !important;
		color: #6b7280 !important;
		line-height: 1.6 !important;
	}

	.search-results .result-excerpt mark {
		background-color: #3b82f6 !important;
		color: white !important;
		padding: 0 0.125rem !important;
		border-radius: 0.125rem !important;
	}
</style>
