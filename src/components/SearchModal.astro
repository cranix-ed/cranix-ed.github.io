---
const isDark = 'dark';
---

<site-search>
	<button
		data-open-modal
		disabled
		aria-label="Search articles"
		aria-keyshortcuts="Control+K"
	>
		<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<circle cx="11" cy="11" r="8"/>
			<path d="m21 21-4.35-4.35"/>
		</svg>
		<span class="search-label" aria-hidden="true">Search</span>
		<kbd class="search-shortcut" style="display: none;">
			<kbd>Ctrl</kbd><kbd>K</kbd>
		</kbd>
	</button>
	<dialog style="padding: 0" aria-label="Search">
		<div id="starlight__search" />
	</dialog>
</site-search>

<script is:inline>
	(() => {
		const openBtn = document.querySelector('button[data-open-modal]');
		const shortcut = openBtn?.querySelector('.search-shortcut');
		if (!openBtn || !(shortcut instanceof HTMLElement)) return;
		const platformKey = shortcut.querySelector('kbd');
		if (platformKey && /(Mac|iPhone|iPod|iPad)/i.test(navigator.platform)) {
			platformKey.textContent = '⌘';
			openBtn.setAttribute('aria-keyshortcuts', 'Meta+K');
		}
		shortcut.style.display = '';
	})();
</script>

<script>
	class SiteSearch extends HTMLElement {
		constructor() {
			super();
			const openBtn = this.querySelector('button[data-open-modal]');
			const dialog = this.querySelector('dialog');

			const onClick = (event) => {
				const isLink = 'href' in (event.target || {});
				if (isLink || (document.body.contains(event.target) && !dialog.contains(event.target))) {
					closeModal();
				}
			};

			const openModal = (event) => {
				dialog.showModal();
				document.body.toggleAttribute('data-search-modal-open', true);
				this.querySelector('input')?.focus();
				event?.stopPropagation();
				window.addEventListener('click', onClick);
			};

			const closeModal = () => {
				dialog.close();
				const searchInput = this.querySelector('input');
				if (searchInput) {
					searchInput.value = '';
				}
			};

			openBtn.addEventListener('click', openModal);
			openBtn.disabled = false;
			dialog.addEventListener('close', () => {
				document.body.toggleAttribute('data-search-modal-open', false);
				window.removeEventListener('click', onClick);
			});

			window.addEventListener('keydown', (e) => {
				if ((e.metaKey === true || e.ctrlKey === true) && e.key === 'k') {
					dialog.open ? closeModal() : openModal();
					e.preventDefault();
				}
			});

			if (!import.meta.env.DEV) {
				window.addEventListener('DOMContentLoaded', () => {
					const onIdle = window.requestIdleCallback || ((cb) => setTimeout(cb, 1));
					onIdle(async () => {
						try {
							const { PagefindUI } = await import('@pagefind/default-ui');
							new PagefindUI({
								element: '#starlight__search',
								baseUrl: import.meta.env.BASE_URL,
								bundlePath: import.meta.env.BASE_URL.replace(/\/$/, '') + '/pagefind/',
								showImages: false,
								showSubResults: true,
								translations: {
								placeholder: 'Search...',
								zero_results: 'No results found',
								footer: ':count results found',
								filters: 'Filters',
								clear_filters: 'Clear filters',
								search_label: 'Search',
							},
							});
						} catch (error) {
							console.warn('Pagefind UI failed to load:', error);
						}
					});
				});
			}
		}
	}

	customElements.define('site-search', SiteSearch);
</script>

<style>
	site-search {
		display: contents;
	}

	button[data-open-modal] {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		border: 0;
		background-color: transparent;
		color: var(--text-muted);
		cursor: pointer;
		height: 2.5rem;
		font-size: 1rem;
		padding: 0 0.5rem;
	}

	@media (min-width: 50rem) {
		button[data-open-modal] {
			border: 1px solid var(--border-color);
			border-radius: 0.5rem;
			padding-inline-start: 0.75rem;
			padding-inline-end: 0.5rem;
			background-color: var(--bg-primary);
			color: var(--text-muted);
			font-size: 0.875rem;
			width: 100%;
			max-width: 22rem;
			transition: border-color 0.2s, color 0.2s;
		}

		button[data-open-modal]:hover {
			border-color: var(--text-muted);
			color: var(--text-primary);
		}

		button[data-open-modal] > :last-child {
			margin-inline-start: auto;
		}
	}

	.search-label {
		display: none;
	}

	@media (min-width: 50rem) {
		.search-label {
			display: inline;
		}
	}

	.search-shortcut {
		display: flex;
		gap: 0.25em;
	}

	.search-shortcut kbd {
		border-radius: 0.25rem;
		font-size: 0.625rem;
		padding-inline: 0.375rem;
		padding-block: 0.125rem;
		background-color: #f3f4f6;
		font-family: ui-monospace, SFMono-Regular, monospace;
		min-width: 1.125rem;
		text-align: center;
	}

	dialog {
		margin: 0;
		background-color: #ffffff;
		border: none;
		width: 100%;
		max-width: 100%;
		height: 100%;
		max-height: 100%;
		box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
	}

	dialog[open] {
		display: flex;
	}

	dialog::backdrop {
		background-color: rgba(0, 0, 0, 0.8);
		-webkit-backdrop-filter: blur(8px);
		backdrop-filter: blur(8px);
	}

	@media (min-width: 50rem) {
		dialog {
			margin: 4rem auto auto;
			border-radius: 16px;
			width: 90%;
			max-width: 52rem;
			height: max-content;
			min-height: 15rem;
			max-height: calc(100% - 8rem);
			animation: slideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		}

		@keyframes slideIn {
			from {
				opacity: 0;
				transform: translateY(-20px) scale(0.98);
			}
			to {
				opacity: 1;
				transform: translateY(0) scale(1);
			}
		}
	}

	html.dark .search-shortcut kbd {
		background-color: var(--bg-tertiary);
	}

	html.dark dialog {
		background-color: var(--bg-primary);
	}
</style>

<style is:global>
	@import url('@pagefind/default-ui/css/ui.css');

	[data-search-modal-open] {
		overflow: hidden;
	}

	#starlight__search {
		width: 100%;
		height: 100%;
		display: flex;
		flex-direction: column;
	}

	#starlight__search * {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	#starlight__search input {
		border: none;
		outline: none;
		box-shadow: none;
	}

	#starlight__search button {
		border: none;
		background: none;
		cursor: pointer;
	}

	#starlight__search .pagefind-ui__form {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 1rem 1.25rem;
		border-bottom: 2px solid #e5e7eb;
		background-color: #ffffff;
	}

	#starlight__search .pagefind-ui__form::before {
		flex-shrink: 0;
		opacity: 0.5;
		width: 18px;
		height: 18px;
		margin-top: 0;
	}

	#starlight__search .pagefind-ui__search-input {
		flex: 1;
		font-size: 1rem;
		color: #111827;
		background: transparent;
	}

	#starlight__search .pagefind-ui__search-clear {
		opacity: 0.5;
		padding: 0.25rem;
		border-radius: 4px;
	}

	#starlight__search .pagefind-ui__search-clear:hover {
		opacity: 1;
		background-color: rgba(0, 0, 0, 0.05);
	}

	#starlight__search .pagefind-ui__results {
		flex: 1;
		overflow-y: auto;
		padding: 0.5rem 0;
	}

	#starlight__search .pagefind-ui__result {
		padding: 0;
		border: none;
		border-bottom: 1px solid #e5e7eb;
		background: none;
	}

	#starlight__search .pagefind-ui__result:last-child {
		border-bottom: none;
	}

	#starlight__search .pagefind-ui__result-title {
		padding: 0.75rem 1.25rem;
		background: none;
	}

	#starlight__search .pagefind-ui__result-title:hover {
		background-color: rgba(37, 99, 235, 0.05);
	}

	#starlight__search .pagefind-ui__result-link {
		font-weight: 600;
		font-size: 0.9375rem;
		color: #111827;
		text-decoration: none;
		display: block;
	}

	#starlight__search .pagefind-ui__result-link:hover {
		color: #2563eb;
	}

	#starlight__search .pagefind-ui__result-excerpt {
		font-size: 0.8125rem;
		color: #6b7280;
		margin-top: 0.375rem;
		line-height: 1.6;
	}

	#starlight__search .pagefind-ui__result-nested {
		padding: 0.5rem 1.25rem 0.5rem 2.5rem;
		background: none;
		border-bottom: 1px solid #e5e7eb;
	}

	#starlight__search .pagefind-ui__result-nested:hover {
		background-color: rgba(37, 99, 235, 0.05);
	}

	#starlight__search .pagefind-ui__result-nested .pagefind-ui__result-link {
		font-weight: 500;
		font-size: 0.875rem;
		color: #374151;
	}

	#starlight__search .pagefind-ui__results-count {
		font-size: 0.8125rem;
		color: #6b7280;
		padding: 0.75rem 1.25rem;
		border-bottom: 1px solid #e5e7eb;
	}

	#starlight__search mark {
		background-color: rgba(251, 191, 36, 0.3);
		color: #92400e;
		padding: 0 2px;
	}

	#starlight__search .pagefind-ui__empty {
		padding: 4rem 2rem;
		text-align: center;
		color: #6b7280;
	}

	html.dark #starlight__search .pagefind-ui__form {
		background-color: var(--bg-primary);
		border-bottom-color: var(--border-color);
	}

	html.dark #starlight__search .pagefind-ui__search-input {
		color: var(--text-primary);
	}

	html.dark #starlight__search .pagefind-ui__result {
		border-bottom-color: var(--border-color);
	}

	html.dark #starlight__search .pagefind-ui__result-title:hover {
		background-color: var(--bg-secondary);
	}

	html.dark #starlight__search .pagefind-ui__result-link {
		color: var(--text-primary);
	}

	html.dark #starlight__search .pagefind-ui__result-link:hover {
		color: #60a5fa;
	}

	html.dark #starlight__search .pagefind-ui__result-excerpt {
		color: var(--text-muted);
	}

	html.dark #starlight__search .pagefind-ui__result-nested {
		border-bottom-color: var(--border-color);
	}

	html.dark #starlight__search .pagefind-ui__result-nested:hover {
		background-color: var(--bg-secondary);
	}

	html.dark #starlight__search .pagefind-ui__result-nested .pagefind-ui__result-link {
		color: var(--text-secondary);
	}

	html.dark #starlight__search .pagefind-ui__results-count {
		color: var(--text-muted);
		border-bottom-color: var(--border-color);
	}

	html.dark #starlight__search mark {
		background-color: rgba(251, 191, 36, 0.3);
		color: #fbbf24;
	}

	html.dark #starlight__search .pagefind-ui__empty {
		color: var(--text-muted);
	}
</style>