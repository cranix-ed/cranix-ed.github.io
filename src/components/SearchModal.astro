---
const isDark = 'dark';
---

<site-search>
	<button
		data-open-modal
		disabled
		aria-label="Search articles"
		aria-keyshortcuts="Control+K"
	>
		<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<circle cx="11" cy="11" r="8"/>
			<path d="m21 21-4.35-4.35"/>
		</svg>
		<span class="search-label" aria-hidden="true">Search</span>
		<kbd class="search-shortcut" style="display: none;">
			<kbd>Ctrl</kbd><kbd>K</kbd>
		</kbd>
	</button>
	<dialog style="padding: 0" aria-label="Search">
		<div class="search-modal-content">
			<div class="search-input-wrapper">
				<svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="11" cy="11" r="8"/>
					<path d="m21 21-4.35-4.35"/>
				</svg>
				<input type="text" class="search-input" placeholder="Search..." />
				<button class="search-clear" style="display: none;">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="18" y1="6" x2="6" y2="18"/>
						<line x1="6" y1="6" x2="18" y2="18"/>
					</svg>
				</button>
			</div>
			<div class="search-results">
				<div class="results-count">Type to search...</div>
				<div class="results-list"></div>
			</div>
		</div>
	</dialog>
</site-search>

<script is:inline>
	(() => {
		const openBtn = document.querySelector('button[data-open-modal]');
		const shortcut = openBtn?.querySelector('.search-shortcut');
		if (!openBtn || !(shortcut instanceof HTMLElement)) return;
		const platformKey = shortcut.querySelector('kbd');
		if (platformKey && /(Mac|iPhone|iPod|iPad)/i.test(navigator.platform)) {
			platformKey.textContent = '⌘';
			openBtn.setAttribute('aria-keyshortcuts', 'Meta+K');
		}
		shortcut.style.display = '';
	})();
</script>

<script>
	class SiteSearch extends HTMLElement {
		constructor() {
			super();
			const openBtn = this.querySelector('button[data-open-modal]');
			const dialog = this.querySelector('dialog');
			const searchInput = this.querySelector('.search-input');
			const searchClear = this.querySelector('.search-clear');
			const resultsCount = this.querySelector('.results-count');
			const resultsList = this.querySelector('.results-list');

			let searchTimeout = null;

			const closeModal = () => {
				dialog.close();
				searchInput.value = '';
				searchClear.style.display = 'none';
				resultsCount.textContent = 'Type to search...';
				resultsList.innerHTML = '';
			};

			const onClick = (event) => {
				const isLink = 'href' in (event.target || {});
				if (isLink || (document.body.contains(event.target) && !dialog.contains(event.target))) {
					closeModal();
				}
			};

			const openModal = (event) => {
				dialog.showModal();
				document.body.toggleAttribute('data-search-modal-open', true);
				searchInput.focus();
				event?.stopPropagation();
				window.addEventListener('click', onClick);
			};

			openBtn.addEventListener('click', openModal);
			openBtn.disabled = false;

			dialog.addEventListener('close', () => {
				document.body.toggleAttribute('data-search-modal-open', false);
				window.removeEventListener('click', onClick);
			});

			searchInput.addEventListener('input', (e) => {
				const query = e.target.value.trim();
				searchClear.style.display = query ? 'block' : 'none';
				
				if (searchTimeout) clearTimeout(searchTimeout);
				
				if (!query) {
					resultsCount.textContent = 'Type to search...';
					resultsList.innerHTML = '';
					return;
				}

				searchTimeout = setTimeout(async () => {
					try {
						const response = await fetch(`/pagefind/search?q=${encodeURIComponent(query)}`);
						const data = await response.json();
						displayResults(data);
					} catch (error) {
						console.warn('Search failed:', error);
						resultsCount.textContent = 'Search unavailable';
					}
				}, 150);
			});

			searchClear.addEventListener('click', () => {
				searchInput.value = '';
				searchClear.style.display = 'none';
				resultsCount.textContent = 'Type to search...';
				resultsList.innerHTML = '';
				searchInput.focus();
			});

			const displayResults = (data) => {
				if (!data.results || data.results.length === 0) {
					resultsCount.textContent = 'No results found';
					resultsList.innerHTML = '';
					return;
				}

				resultsCount.textContent = `${data.results.length} results for "${searchInput.value}"`;
				
				let html = '';
				data.results.forEach((result) => {
					const title = highlightText(result.meta.title || result.url, searchInput.value);
					const excerpt = result.excerpt ? highlightText(result.excerpt, searchInput.value) : '';
					
					html += `
						<div class="result-item">
							<a href="${result.url}" class="result-title">${title}</a>
					`;
					
					if (result.subresults && result.subresults.length > 0) {
						result.subresults.forEach((sub) => {
							const subTitle = highlightText(sub.title, searchInput.value);
							const subExcerpt = sub.excerpt ? highlightText(sub.excerpt, searchInput.value) : '';
							html += `
								<div class="result-nested">
									<svg class="nested-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M18 8v6l-3-3M12 19h7l-7-7v7Z"/>
									</svg>
									<div class="nested-content">
										<a href="${result.url}#${sub.id}" class="nested-title">${subTitle}</a>
										${subExcerpt ? `<p class="nested-excerpt">${subExcerpt}</p>` : ''}
									</div>
								</div>
							`;
						});
					}
					
					html += '</div>';
				});
				
				resultsList.innerHTML = html;
			};

			const highlightText = (text, query) => {
				if (!text) return '';
				const regex = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
				return text.replace(regex, '<mark>$1</mark>');
			};

			window.addEventListener('keydown', (e) => {
				if ((e.metaKey === true || e.ctrlKey === true) && e.key === 'k') {
					dialog.open ? closeModal() : openModal();
					e.preventDefault();
				}
				
				if (e.key === 'Escape' && dialog.open) {
					closeModal();
				}
			});
		}
	}

	customElements.define('site-search', SiteSearch);
</script>

<style>
	site-search {
		display: contents;
	}

	button[data-open-modal] {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		border: 0;
		background-color: transparent;
		color: var(--text-muted);
		cursor: pointer;
		height: 2.5rem;
		font-size: 1rem;
		padding: 0 0.5rem;
	}

	@media (min-width: 50rem) {
		button[data-open-modal] {
			border: 1px solid var(--border-color);
			border-radius: 0.5rem;
			padding-inline-start: 0.75rem;
			padding-inline-end: 0.5rem;
			background-color: var(--bg-primary);
			color: var(--text-muted);
			font-size: 0.875rem;
			width: 100%;
			max-width: 22rem;
			transition: border-color 0.2s, color 0.2s;
		}

		button[data-open-modal]:hover {
			border-color: var(--text-muted);
			color: var(--text-primary);
		}

		button[data-open-modal] > :last-child {
			margin-inline-start: auto;
		}
	}

	.search-label {
		display: none;
	}

	@media (min-width: 50rem) {
		.search-label {
			display: inline;
		}
	}

	.search-shortcut {
		display: flex;
		gap: 0.25em;
	}

	.search-shortcut kbd {
		border-radius: 0.25rem;
		font-size: 0.625rem;
		padding-inline: 0.375rem;
		padding-block: 0.125rem;
		background-color: #f3f4f6;
		font-family: ui-monospace, SFMono-Regular, monospace;
		min-width: 1.125rem;
		text-align: center;
	}

	dialog {
		margin: 0;
		background-color: #f8fafc;
		border: none;
		width: 100%;
		max-width: 100%;
		height: 100%;
		max-height: 100%;
		box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
	}

	dialog[open] {
		display: flex;
	}

	dialog::backdrop {
		background-color: rgba(0, 0, 0, 0.8);
		-webkit-backdrop-filter: blur(8px);
		backdrop-filter: blur(8px);
	}

	.search-modal-content {
		display: flex;
		flex-direction: column;
		height: 100%;
		width: 100%;
	}

	.search-input-wrapper {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 1rem;
		background-color: #ffffff;
		border-bottom: 1px solid #e2e8f0;
	}

	.search-icon {
		flex-shrink: 0;
		color: #94a3b8;
	}

	.search-input {
		flex: 1;
		font-size: 1rem;
		color: #1e293b;
		border: none;
		outline: none;
		background: transparent;
	}

	.search-input::placeholder {
		color: #94a3b8;
	}

	.search-clear {
		flex-shrink: 0;
		display: none;
		padding: 0.375rem;
		color: #94a3b8;
		border: none;
		background: transparent;
		cursor: pointer;
		border-radius: 4px;
		transition: color 0.2s, background-color 0.2s;
	}

	.search-clear:hover {
		color: #1e293b;
		background-color: #f1f5f9;
	}

	.search-results {
		flex: 1;
		overflow-y: auto;
		display: flex;
		flex-direction: column;
	}

	.results-count {
		font-size: 0.8125rem;
		color: #64748b;
		padding: 0.75rem 1rem;
		font-weight: 500;
	}

	.results-list {
		flex: 1;
		overflow-y: auto;
	}

	.result-item {
		border: 1px solid #e2e8f0;
		border-radius: 8px;
		margin: 0 1rem 0.25rem;
		overflow: hidden;
		background-color: #ffffff;
	}

	.result-title {
		display: block;
		padding: 0.75rem 1rem;
		font-weight: 600;
		font-size: 0.9375rem;
		color: #1e293b;
		text-decoration: none;
		background-color: #ffffff;
		border-bottom: 1px solid #e2e8f0;
		transition: background-color 0.2s;
	}

	.result-title:hover {
		background-color: #f8fafc;
	}

	.result-nested {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		padding: 0.625rem 1rem;
		border-bottom: 1px solid #f1f5f9;
		background-color: #fafafa;
		transition: background-color 0.2s;
	}

	.result-nested:last-child {
		border-bottom: none;
	}

	.result-nested:hover {
		background-color: #f1f5f9;
	}

	.nested-icon {
		flex-shrink: 0;
		color: #94a3b8;
		margin-top: 0.125rem;
	}

	.nested-content {
		flex: 1;
		min-width: 0;
	}

	.nested-title {
		display: block;
		font-weight: 500;
		font-size: 0.875rem;
		color: #475569;
		text-decoration: none;
		transition: color 0.2s;
	}

	.nested-title:hover {
		color: #2563eb;
	}

	.nested-excerpt {
		margin: 0.25rem 0 0;
		font-size: 0.8125rem;
		color: #64748b;
		line-height: 1.5;
		white-space: pre-wrap;
	}

	.result-item mark {
		background-color: rgba(251, 191, 36, 0.4);
		color: #92400e;
		padding: 0 2px;
		border-radius: 2px;
	}

	@media (min-width: 50rem) {
		dialog {
			margin: 4rem auto auto;
			border-radius: 12px;
			width: 90%;
			max-width: 52rem;
			height: max-content;
			min-height: 15rem;
			max-height: calc(100% - 8rem);
			animation: slideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		}

		@keyframes slideIn {
			from {
				opacity: 0;
				transform: translateY(-20px) scale(0.98);
			}
			to {
				opacity: 1;
				transform: translateY(0) scale(1);
			}
		}
	}

	html.dark .search-shortcut kbd {
		background-color: var(--bg-tertiary);
	}

	html.dark dialog {
		background-color: var(--bg-primary);
	}

	html.dark .search-modal-content {
		background-color: var(--bg-primary);
	}

	html.dark .search-input-wrapper {
		background-color: var(--bg-secondary);
		border-bottom-color: var(--border-color);
	}

	html.dark .search-icon {
		color: var(--text-muted);
	}

	html.dark .search-input {
		color: var(--text-primary);
	}

	html.dark .search-input::placeholder {
		color: var(--text-muted);
	}

	html.dark .search-clear {
		color: var(--text-muted);
	}

	html.dark .search-clear:hover {
		color: var(--text-primary);
		background-color: var(--bg-tertiary);
	}

	html.dark .results-count {
		color: var(--text-muted);
	}

	html.dark .result-item {
		border-color: var(--border-color);
		background-color: var(--bg-secondary);
	}

	html.dark .result-title {
		color: var(--text-primary);
		background-color: var(--bg-secondary);
		border-bottom-color: var(--border-color);
	}

	html.dark .result-title:hover {
		background-color: var(--bg-tertiary);
	}

	html.dark .result-nested {
		background-color: var(--bg-tertiary);
		border-bottom-color: var(--border-color);
	}

	html.dark .result-nested:hover {
		background-color: rgba(59, 130, 246, 0.1);
	}

	html.dark .nested-icon {
		color: var(--text-muted);
	}

	html.dark .nested-title {
		color: var(--text-secondary);
	}

	html.dark .nested-title:hover {
		color: #60a5fa;
	}

	html.dark .nested-excerpt {
		color: var(--text-muted);
	}

	html.dark .result-item mark {
		background-color: rgba(251, 191, 36, 0.3);
		color: #fbbf24;
	}
</style>