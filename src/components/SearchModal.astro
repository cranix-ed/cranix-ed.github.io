---
const isDark = 'dark';
---

<site-search>
	<button
		data-open-modal
		disabled
		aria-label="Search articles"
		aria-keyshortcuts="Control+K"
	>
		<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<circle cx="11" cy="11" r="8"/>
			<path d="m21 21-4.35-4.35"/>
		</svg>
		<span class="search-label" aria-hidden="true">Search</span>
		<kbd class="search-shortcut" style="display: none;">
			<kbd>Ctrl</kbd><kbd>K</kbd>
		</kbd>
	</button>
	<dialog style="padding: 0" aria-label="Search">
		<div id="search-container"></div>
	</dialog>
</site-search>

<script is:inline>
	(() => {
		const openBtn = document.querySelector('button[data-open-modal]');
		const shortcut = openBtn?.querySelector('.search-shortcut');
		if (!openBtn || !(shortcut instanceof HTMLElement)) return;
		const platformKey = shortcut.querySelector('kbd');
		if (platformKey && /(Mac|iPhone|iPod|iPad)/i.test(navigator.platform)) {
			platformKey.textContent = '⌘';
			openBtn.setAttribute('aria-keyshortcuts', 'Meta+K');
		}
		shortcut.style.display = '';
	})();
</script>

<script>
	const searchStyles = `
		:root {
			--search-bg-primary: #ffffff;
			--search-bg-secondary: #f8fafc;
			--search-border-color: #e2e8f0;
			--search-text-primary: #1e293b;
			--search-text-secondary: #475569;
			--search-text-muted: #64748b;
			--search-accent-color: #2563eb;
			--search-highlight-bg: rgba(251, 191, 36, 0.4);
			--search-highlight-color: #92400e;
		}

		html.dark {
			--search-bg-primary: #1e293b;
			--search-bg-secondary: #334155;
			--search-border-color: #475569;
			--search-text-primary: #f1f5f9;
			--search-text-secondary: #cbd5e1;
			--search-text-muted: #94a3b8;
			--search-accent-color: #60a5fa;
			--search-highlight-bg: rgba(251, 191, 36, 0.3);
			--search-highlight-color: #fbbf24;
		}

		site-search #search-container .pagefind-ui {
			display: flex !important;
			flex-direction: column !important;
			height: 100% !important;
			width: 100% !important;
			background: transparent !important;
		}

		site-search #search-container .pagefind-ui * {
			box-sizing: border-box !important;
			margin: 0 !important;
			padding: 0 !important;
			font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif !important;
		}

		site-search #search-container .pagefind-ui__search-input {
			font-size: 1rem !important;
			padding: 0.75rem 2.5rem !important;
			border: none !important;
			border-bottom: 2px solid var(--search-border-color) !important;
			background-color: var(--search-bg-primary) !important;
			outline: none !important;
			color: var(--search-text-primary) !important;
			border-radius: 0 !important;
			box-shadow: none !important;
		}

		site-search #search-container .pagefind-ui__search-input::placeholder {
			color: var(--search-text-muted) !important;
		}

		site-search #search-container .pagefind-ui__results-area {
			flex: 1 !important;
			overflow-y: auto !important;
			background-color: var(--search-bg-primary) !important;
		}

		site-search #search-container .pagefind-ui__result {
			padding: 0.75rem !important;
			border-bottom: 1px solid var(--search-border-color) !important;
			display: block !important;
			cursor: pointer !important;
		}

		site-search #search-container .pagefind-ui__result:hover {
			background-color: var(--search-bg-secondary) !important;
		}

		site-search #search-container .pagefind-ui__result-title {
			font-weight: 600 !important;
			font-size: 0.9375rem !important;
			color: var(--search-text-primary) !important;
			text-decoration: none !important;
			display: block !important;
			margin-bottom: 0.25rem !important;
		}

		site-search #search-container .pagefind-ui__result-link {
			color: var(--search-text-secondary) !important;
			font-size: 0.8125rem !important;
			text-decoration: none !important;
			display: block !important;
			margin-bottom: 0.25rem !important;
		}

		site-search #search-container .pagefind-ui__subresult {
			padding-left: 1.5rem !important;
			padding-top: 0.25rem !important;
			padding-bottom: 0.25rem !important;
		}

		site-search #search-container .pagefind-ui__subresult-link {
			color: var(--search-text-muted) !important;
			font-size: 0.8125rem !important;
			text-decoration: none !important;
			display: block !important;
		}

		site-search #search-container .pagefind-ui__subresult-link:hover {
			color: var(--search-accent-color) !important;
		}

		site-search #search-container .pagefind-ui__result-excerpt {
			font-size: 0.8125rem !important;
			color: var(--search-text-muted) !important;
			margin-top: 0.25rem !important;
			line-height: 1.5 !important;
			display: block !important;
		}

		site-search #search-container .pagefind-ui__search-clear {
			position: absolute !important;
			right: 0.75rem !important;
			top: 50% !important;
			transform: translateY(-50%) !important;
			background: none !important;
			border: none !important;
			cursor: pointer !important;
			color: var(--search-text-muted) !important;
			font-size: 1.25rem !important;
			padding: 0.25rem !important;
			width: auto !important;
			height: auto !important;
		}

		site-search #search-container .pagefind-ui__search-clear:hover {
			color: var(--search-text-primary) !important;
		}

		site-search #search-container .pagefind-ui__search-icon {
			position: absolute !important;
			left: 0.75rem !important;
			top: 50% !important;
			transform: translateY(-50%) !important;
			color: var(--search-text-muted) !important;
			width: 1rem !important;
			height: 1rem !important;
		}

		site-search #search-container .pagefind-ui__form {
			position: relative !important;
			display: flex !important;
			align-items: center !important;
			background-color: var(--search-bg-primary) !important;
		}

		site-search #search-container .pagefind-ui__empty,
		site-search #search-container .pagefind-ui__message {
			padding: 2rem !important;
			text-align: center !important;
			color: var(--search-text-muted) !important;
			font-size: 0.875rem !important;
			background-color: var(--search-bg-primary) !important;
		}

		site-search #search-container .pagefind-ui__result mark {
			background-color: var(--search-highlight-bg) !important;
			color: var(--search-highlight-color) !important;
			padding: 0 2px !important;
			border-radius: 2px !important;
		}

		site-search #search-container .pagefind-ui__results-count {
			display: none !important;
		}

		site-search #search-container .pagefind-ui__result-image {
			display: none !important;
		}
	`;

	class SiteSearch extends HTMLElement {
		constructor() {
			super();
			const openBtn = this.querySelector('button[data-open-modal]');
			const dialog = this.querySelector('dialog');
			const container = this.querySelector('#search-container');
			
			let pagefindUI = null;
			let isLoading = false;
			let styleInjected = false;

			const closeModal = () => {
				if (dialog.open) {
					dialog.close();
					document.body.toggleAttribute('data-search-modal-open', false);
				}
			};

			const onClick = (event) => {
				const isLink = event.target.closest('a');
				if (isLink || (document.body.contains(event.target) && !dialog.contains(event.target))) {
					closeModal();
				}
			};

			const injectStyles = () => {
				if (styleInjected) return;
				const style = document.createElement('style');
				style.textContent = searchStyles;
				style.setAttribute('data-search-styles', '');
				document.head.appendChild(style);
				styleInjected = true;
			};

			const loadPagefind = async () => {
				return new Promise((resolve) => {
					if (window.PagefindUI) {
						resolve(window.PagefindUI);
						return;
					}
					if (isLoading) {
						setTimeout(() => loadPagefind().then(resolve), 100);
						return;
					}

					isLoading = true;
					
					const script = document.createElement('script');
					script.src = `${window.location.origin}/pagefind/pagefind-ui.js`;
					script.onload = () => {
						isLoading = false;
						resolve(window.PagefindUI);
					};
					script.onerror = () => {
						isLoading = false;
						resolve(null);
					};
					document.head.appendChild(script);
				});
			};

			const openModal = async (event) => {
				if (!pagefindUI) {
					const PagefindUI = await loadPagefind();
					if (PagefindUI) {
						injectStyles();
						setTimeout(() => {
							pagefindUI = new PagefindUI({
								element: container,
								showImages: false,
								showSubResults: true,
								highlightParam: 'highlight',
								placeholder: 'Search...',
								basePath: `${window.location.origin}/pagefind/`,
							});
						}, 50);
					}
				}
				dialog.showModal();
				document.body.toggleAttribute('data-search-modal-open', true);
				event?.stopPropagation();
				window.addEventListener('click', onClick);
			};

			openBtn.addEventListener('click', openModal);
			openBtn.disabled = false;

			dialog.addEventListener('close', () => {
				document.body.toggleAttribute('data-search-modal-open', false);
				window.removeEventListener('click', onClick);
			});

			window.addEventListener('keydown', (e) => {
				if ((e.metaKey === true || e.ctrlKey === true) && e.key === 'k') {
					dialog.open ? closeModal() : openModal();
					e.preventDefault();
				}
				
				if (e.key === 'Escape' && dialog.open) {
					closeModal();
				}
			});
		}
	}

	customElements.define('site-search', SiteSearch);
</script>

<style>
	site-search {
		display: contents;
	}

	button[data-open-modal] {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		border: 0;
		background-color: transparent;
		color: var(--text-muted);
		cursor: pointer;
		height: 2.5rem;
		font-size: 1rem;
		padding: 0 0.5rem;
	}

	@media (min-width: 50rem) {
		button[data-open-modal] {
			border: 1px solid var(--border-color);
			border-radius: 0.5rem;
			padding-inline-start: 0.75rem;
			padding-inline-end: 0.5rem;
			background-color: var(--bg-primary);
			color: var(--text-muted);
			font-size: 0.875rem;
			width: 100%;
			max-width: 22rem;
			transition: border-color 0.2s, color 0.2s;
		}

		button[data-open-modal]:hover {
			border-color: var(--text-muted);
			color: var(--text-primary);
		}

		button[data-open-modal] > :last-child {
			margin-inline-start: auto;
		}
	}

	.search-label {
		display: none;
	}

	@media (min-width: 50rem) {
		.search-label {
			display: inline;
		}
	}

	.search-shortcut {
		display: flex;
		gap: 0.25em;
	}

	.search-shortcut kbd {
		border-radius: 0.25rem;
		font-size: 0.625rem;
		padding-inline: 0.375rem;
		padding-block: 0.125rem;
		background-color: #f3f4f6;
		font-family: ui-monospace, SFMono-Regular, monospace;
		min-width: 1.125rem;
		text-align: center;
	}

	dialog {
		margin: 0;
		background-color: #f8fafc;
		border: none;
		width: 100%;
		max-width: 100%;
		height: 100%;
		max-height: 100%;
		box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
	}

	dialog[open] {
		display: flex;
	}

	dialog::backdrop {
		background-color: rgba(0, 0, 0, 0.8);
		-webkit-backdrop-filter: blur(8px);
		backdrop-filter: blur(8px);
	}

	#search-container {
		width: 100%;
		height: 100%;
	}

	@media (min-width: 50rem) {
		dialog {
			margin: 4rem auto auto;
			border-radius: 12px;
			width: 90%;
			max-width: 52rem;
			height: max-content;
			min-height: 15rem;
			max-height: calc(100% - 8rem);
			animation: slideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		}

		@keyframes slideIn {
			from {
				opacity: 0;
				transform: translateY(-20px) scale(0.98);
			}
			to {
				opacity: 1;
				transform: translateY(0) scale(1);
			}
		}
	}

	html.dark .search-shortcut kbd {
		background-color: var(--bg-tertiary);
	}

	html.dark dialog {
		background-color: var(--bg-primary);
	}
</style>