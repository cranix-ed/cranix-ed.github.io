---
const isDark = 'dark';
---

<site-search>
	<button
		data-open-modal
		disabled
		aria-label="Search articles"
		aria-keyshortcuts="Control+K"
	>
		<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<circle cx="11" cy="11" r="8"/>
			<path d="m21 21-4.35-4.35"/>
		</svg>
		<span class="search-label" aria-hidden="true">Search</span>
		<kbd class="search-shortcut" style="display: none;">
			<kbd>Ctrl</kbd><kbd>K</kbd>
		</kbd>
	</button>
	<dialog style="padding: 0" aria-label="Search">
		<div id="search-container"></div>
	</dialog>
</site-search>

<script is:inline>
	(() => {
		const openBtn = document.querySelector('button[data-open-modal]');
		const shortcut = openBtn?.querySelector('.search-shortcut');
		if (!openBtn || !(shortcut instanceof HTMLElement)) return;
		const platformKey = shortcut.querySelector('kbd');
		if (platformKey && /(Mac|iPhone|iPod|iPad)/i.test(navigator.platform)) {
			platformKey.textContent = '⌘';
			openBtn.setAttribute('aria-keyshortcuts', 'Meta+K');
		}
		shortcut.style.display = '';
	})();
</script>

<script>
	import '@pagefind/default-ui';

	class SiteSearch extends HTMLElement {
		constructor() {
			super();
			const openBtn = this.querySelector('button[data-open-modal]');
			const dialog = this.querySelector('dialog');
			const container = this.querySelector('#search-container');
			
			let pagefindUI = null;

			const closeModal = () => {
				if (dialog.open) {
					dialog.close();
					document.body.toggleAttribute('data-search-modal-open', false);
				}
			};

			const onClick = (event) => {
				const isLink = event.target.closest('a');
				if (isLink || (document.body.contains(event.target) && !dialog.contains(event.target))) {
					closeModal();
				}
			};

			const openModal = (event) => {
				if (!pagefindUI) {
					pagefindUI = new PagefindUI({
						element: container,
						showImages: false,
						showSubResults: true,
						highlightParam: 'highlight',
						placeholder: 'Search...',
					});
				}
				dialog.showModal();
				document.body.toggleAttribute('data-search-modal-open', true);
				event?.stopPropagation();
				window.addEventListener('click', onClick);
			};

			openBtn.addEventListener('click', openModal);
			openBtn.disabled = false;

			dialog.addEventListener('close', () => {
				document.body.toggleAttribute('data-search-modal-open', false);
				window.removeEventListener('click', onClick);
			});

			window.addEventListener('keydown', (e) => {
				if ((e.metaKey === true || e.ctrlKey === true) && e.key === 'k') {
					dialog.open ? closeModal() : openModal();
					e.preventDefault();
				}
				
				if (e.key === 'Escape' && dialog.open) {
					closeModal();
				}
			});
		}
	}

	customElements.define('site-search', SiteSearch);
</script>

<style>
	site-search {
		display: contents;
	}

	button[data-open-modal] {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		border: 0;
		background-color: transparent;
		color: var(--text-muted);
		cursor: pointer;
		height: 2.5rem;
		font-size: 1rem;
		padding: 0 0.5rem;
	}

	@media (min-width: 50rem) {
		button[data-open-modal] {
			border: 1px solid var(--border-color);
			border-radius: 0.5rem;
			padding-inline-start: 0.75rem;
			padding-inline-end: 0.5rem;
			background-color: var(--bg-primary);
			color: var(--text-muted);
			font-size: 0.875rem;
			width: 100%;
			max-width: 22rem;
			transition: border-color 0.2s, color 0.2s;
		}

		button[data-open-modal]:hover {
			border-color: var(--text-muted);
			color: var(--text-primary);
		}

		button[data-open-modal] > :last-child {
			margin-inline-start: auto;
		}
	}

	.search-label {
		display: none;
	}

	@media (min-width: 50rem) {
		.search-label {
			display: inline;
		}
	}

	.search-shortcut {
		display: flex;
		gap: 0.25em;
	}

	.search-shortcut kbd {
		border-radius: 0.25rem;
		font-size: 0.625rem;
		padding-inline: 0.375rem;
		padding-block: 0.125rem;
		background-color: #f3f4f6;
		font-family: ui-monospace, SFMono-Regular, monospace;
		min-width: 1.125rem;
		text-align: center;
	}

	dialog {
		margin: 0;
		background-color: #f8fafc;
		border: none;
		width: 100%;
		max-width: 100%;
		height: 100%;
		max-height: 100%;
		box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
	}

	dialog[open] {
		display: flex;
	}

	dialog::backdrop {
		background-color: rgba(0, 0, 0, 0.8);
		-webkit-backdrop-filter: blur(8px);
		backdrop-filter: blur(8px);
	}

	#search-container {
		width: 100%;
		height: 100%;
	}

	@media (min-width: 50rem) {
		dialog {
			margin: 4rem auto auto;
			border-radius: 12px;
			width: 90%;
			max-width: 52rem;
			height: max-content;
			min-height: 15rem;
			max-height: calc(100% - 8rem);
			animation: slideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		}

		@keyframes slideIn {
			from {
				opacity: 0;
				transform: translateY(-20px) scale(0.98);
			}
			to {
				opacity: 1;
				transform: translateY(0) scale(1);
			}
		}
	}

	html.dark .search-shortcut kbd {
		background-color: var(--bg-tertiary);
	}

	html.dark dialog {
		background-color: var(--bg-primary);
	}

	.pagefind-ui {
		display: flex;
		flex-direction: column;
		height: 100%;
		width: 100%;
	}

	.pagefind-ui__search-input {
		font-size: 1rem;
		padding: 0.75rem;
		border: none;
		border-bottom: 1px solid #e2e8f0;
		background-color: #ffffff;
		outline: none;
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
	}

	.pagefind-ui__results-area {
		flex: 1;
		overflow-y: auto;
	}

	.pagefind-ui__result {
		padding: 0.5rem 0.75rem;
		border-bottom: 1px solid #f1f5f9;
	}

	.pagefind-ui__result:hover {
		background-color: #f8fafc;
	}

	.pagefind-ui__result-title {
		font-weight: 600;
		font-size: 0.9375rem;
		color: #1e293b;
		text-decoration: none;
		display: block;
	}

	.pagefind-ui__result-link {
		color: #475569;
		font-size: 0.8125rem;
		text-decoration: none;
	}

	.pagefind-ui__subresult {
		padding-left: 1.5rem;
		padding-top: 0.25rem;
		padding-bottom: 0.25rem;
	}

	.pagefind-ui__subresult-link {
		color: #64748b;
		font-size: 0.8125rem;
		text-decoration: none;
	}

	.pagefind-ui__subresult-link:hover {
		color: #2563eb;
	}

	.pagefind-ui__result-excerpt {
		font-size: 0.8125rem;
		color: #64748b;
		margin-top: 0.25rem;
	}

	.pagefind-ui__search-clear {
		position: absolute;
		right: 1rem;
		top: 50%;
		transform: translateY(-50%);
		background: none;
		border: none;
		cursor: pointer;
		color: #94a3b8;
	}

	.pagefind-ui__search-clear:hover {
		color: #1e293b;
	}

	.pagefind-ui__search-icon {
		position: absolute;
		left: 1rem;
		top: 50%;
		transform: translateY(-50%);
		color: #94a3b8;
	}

	.pagefind-ui__form {
		position: relative;
		display: flex;
		align-items: center;
	}

	.pagefind-ui__empty,
	.pagefind-ui__message {
		padding: 1rem;
		text-align: center;
		color: #64748b;
		font-size: 0.875rem;
	}

	.pagefind-ui__result mark {
		background-color: rgba(251, 191, 36, 0.4);
		color: #92400e;
		padding: 0 2px;
		border-radius: 2px;
	}

	html.dark .pagefind-ui__search-input {
		background-color: var(--bg-secondary);
		border-bottom-color: var(--border-color);
		color: var(--text-primary);
	}

	html.dark .pagefind-ui__search-input::placeholder {
		color: var(--text-muted);
	}

	html.dark .pagefind-ui__search-icon,
	html.dark .pagefind-ui__search-clear {
		color: var(--text-muted);
	}

	html.dark .pagefind-ui__search-clear:hover {
		color: var(--text-primary);
	}

	html.dark .pagefind-ui__result {
		border-bottom-color: var(--border-color);
	}

	html.dark .pagefind-ui__result:hover {
		background-color: var(--bg-tertiary);
	}

	html.dark .pagefind-ui__result-title {
		color: var(--text-primary);
	}

	html.dark .pagefind-ui__result-link {
		color: var(--text-secondary);
	}

	html.dark .pagefind-ui__subresult-link {
		color: var(--text-muted);
	}

	html.dark .pagefind-ui__subresult-link:hover {
		color: #60a5fa;
	}

	html.dark .pagefind-ui__result-excerpt {
		color: var(--text-muted);
	}

	html.dark .pagefind-ui__empty,
	html.dark .pagefind-ui__message {
		color: var(--text-muted);
	}

	html.dark .pagefind-ui__result mark {
		background-color: rgba(251, 191, 36, 0.3);
		color: #fbbf24;
	}
</style>