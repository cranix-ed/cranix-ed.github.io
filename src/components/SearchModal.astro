---
const isDark = 'dark';
---

<site-search>
	<button
		data-open-modal
		disabled
		aria-label="Search articles"
		aria-keyshortcuts="Control+K"
	>
		<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<circle cx="11" cy="11" r="8"/>
			<path d="m21 21-4.35-4.35"/>
		</svg>
		<span class="search-label" aria-hidden="true">Search</span>
		<kbd class="search-shortcut" style="display: none;">
			<kbd>Ctrl</kbd><kbd>K</kbd>
		</kbd>
	</button>
	<dialog aria-label="Search">
		<div class="search-modal">
			<div class="search-header">
				<svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="11" cy="11" r="8"/>
					<path d="m21 21-4.35-4.35"/>
				</svg>
				<input 
					type="text" 
					class="search-input" 
					placeholder="Search..." 
					autocomplete="off"
					spellcheck="false"
				/>
				<button class="search-clear" style="display: none;">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="18" y1="6" x2="6" y2="18"/>
						<line x1="6" y1="6" x2="18" y2="18"/>
					</svg>
				</button>
				<span class="search-shortcut-modal">
					<kbd>ESC</kbd>
				</span>
			</div>
			<div class="search-results">
				<div class="search-loading" style="display: none;">
					<div class="spinner"></div>
					<span>Loading...</span>
				</div>
				<div class="search-empty" style="display: none;">
					<p>No results found for "<span class="search-term"></span>"</p>
				</div>
				<div class="search-error" style="display: none;">
					<p>Search is unavailable. Please try again later.</p>
				</div>
				<div class="results-list"></div>
			</div>
		</div>
	</dialog>
</site-search>

<script is:inline>
	(() => {
		const openBtn = document.querySelector('button[data-open-modal]');
		const shortcut = openBtn?.querySelector('.search-shortcut');
		if (!openBtn || !(shortcut instanceof HTMLElement)) return;
		const platformKey = shortcut.querySelector('kbd');
		if (platformKey && /(Mac|iPhone|iPod|iPad)/i.test(navigator.platform)) {
			platformKey.textContent = '⌘';
			openBtn.setAttribute('aria-keyshortcuts', 'Meta+K');
		}
		shortcut.style.display = '';
	})();
</script>

<script>
	class SiteSearch extends HTMLElement {
		constructor() {
			super();
			const openBtn = this.querySelector('button[data-open-modal]');
			const dialog = this.querySelector('dialog');
			const input = this.querySelector('.search-input');
			const clearBtn = this.querySelector('.search-clear');
			const resultsList = this.querySelector('.results-list');
			const loading = this.querySelector('.search-loading');
			const empty = this.querySelector('.search-empty');
			const error = this.querySelector('.search-error');
			const searchTerm = this.querySelector('.search-term');

			let searchTimeout = null;
			let isLoading = false;

			const closeModal = () => {
				if (dialog.open) {
					dialog.close();
					document.body.toggleAttribute('data-search-modal-open', false);
					input.value = '';
					clearBtn.style.display = 'none';
					resultsList.innerHTML = '';
					empty.style.display = 'none';
					error.style.display = 'none';
				}
			};

			const showLoading = () => {
				loading.style.display = 'flex';
				empty.style.display = 'none';
				error.style.display = 'none';
				resultsList.innerHTML = '';
			};

			const showResults = (results) => {
				loading.style.display = 'none';
				error.style.display = 'none';
				if (results.length === 0) {
					searchTerm.textContent = input.value;
					empty.style.display = 'flex';
					resultsList.innerHTML = '';
					return;
				}

				empty.style.display = 'none';
				resultsList.innerHTML = results.map(result => this.renderResult(result)).join('');
			};

			const showError = () => {
				loading.style.display = 'none';
				empty.style.display = 'none';
				error.style.display = 'flex';
				resultsList.innerHTML = '';
			};

			const highlightText = (text, query) => {
				if (!text || !query) return text;
				const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
				const regex = new RegExp(`(${escaped})`, 'gi');
				return text.replace(regex, '<mark>$1</mark>');
			};

			this.renderResult = (result) => {
				const title = highlightText(result.title || result.url.split('/').pop().replace(/-/g, ' '), input.value);
				const excerpt = result.excerpt ? highlightText(result.excerpt.substring(0, 150) + '...', input.value) : '';
				const path = result.url.replace('/blog/', '');
				
				return `
					<a href="${result.url}" class="result-item">
						<div class="result-title">${title}</div>
						${excerpt ? `<div class="result-excerpt">${excerpt}</div>` : ''}
						<div class="result-path">/${path}</div>
					</a>
				`;
			};

			const performSearch = async (query) => {
				if (!query.trim()) {
					resultsList.innerHTML = '';
					loading.style.display = 'none';
					empty.style.display = 'none';
					error.style.display = 'none';
					return;
				}

				showLoading();
				isLoading = true;

				try {
					const response = await fetch(`/pagefind/search?q=${encodeURIComponent(query)}`);
					if (!response.ok) throw new Error('Network error');
					
					const data = await response.json();
					const results = [];
					
					for (const result of data.results) {
						let title = result.meta?.title || '';
						let excerpt = result.excerpt || '';
						
						if (!title) {
							const urlParts = result.url.split('/');
							title = urlParts[urlParts.length - 1].replace(/-/g, ' ');
						}
						
						results.push({
							url: result.url,
							title,
							excerpt
						});
					}
					
					showResults(results);
				} catch {
					showError();
				} finally {
					isLoading = false;
				}
			};

			const handleInput = () => {
				clearBtn.style.display = input.value ? 'flex' : 'none';
				
				if (searchTimeout) clearTimeout(searchTimeout);
				searchTimeout = setTimeout(() => {
					performSearch(input.value);
				}, 150);
			};

			const openModal = () => {
				dialog.showModal();
				document.body.toggleAttribute('data-search-modal-open', true);
				input.focus();
			};

			openBtn.addEventListener('click', openModal);
			openBtn.disabled = false;

			input.addEventListener('input', handleInput);
			input.addEventListener('keydown', (e) => {
				if (e.key === 'Escape') {
					closeModal();
				}
			});

			clearBtn.addEventListener('click', () => {
				input.value = '';
				clearBtn.style.display = 'none';
				resultsList.innerHTML = '';
				empty.style.display = 'none';
				input.focus();
			});

			dialog.addEventListener('close', () => {
				document.body.toggleAttribute('data-search-modal-open', false);
			});

			window.addEventListener('keydown', (e) => {
				if ((e.metaKey === true || e.ctrlKey === true) && e.key === 'k') {
					e.preventDefault();
					if (dialog.open) {
						closeModal();
					} else {
						openModal();
					}
				}
				
				if (e.key === 'Escape' && dialog.open) {
					closeModal();
				}
			});
		}
	}

	customElements.define('site-search', SiteSearch);
</script>

<style>
	site-search {
		display: contents;
	}

	button[data-open-modal] {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		border: 0;
		background-color: transparent;
		color: var(--text-muted);
		cursor: pointer;
		height: 2.5rem;
		font-size: 1rem;
		padding: 0 0.5rem;
	}

	@media (min-width: 50rem) {
		button[data-open-modal] {
			border: 1px solid var(--border-color);
			border-radius: 0.5rem;
			padding-inline-start: 0.75rem;
			padding-inline-end: 0.5rem;
			background-color: var(--bg-primary);
			color: var(--text-muted);
			font-size: 0.875rem;
			width: 100%;
			max-width: 22rem;
			transition: border-color 0.2s, color 0.2s;
		}

		button[data-open-modal]:hover {
			border-color: var(--text-muted);
			color: var(--text-primary);
		}

		button[data-open-modal] > :last-child {
			margin-inline-start: auto;
		}
	}

	.search-label {
		display: none;
	}

	@media (min-width: 50rem) {
		.search-label {
			display: inline;
		}
	}

	.search-shortcut {
		display: flex;
		gap: 0.25em;
	}

	.search-shortcut kbd {
		border-radius: 0.25rem;
		font-size: 0.625rem;
		padding-inline: 0.375rem;
		padding-block: 0.125rem;
		background-color: #f3f4f6;
		font-family: ui-monospace, SFMono-Regular, monospace;
		min-width: 1.125rem;
		text-align: center;
	}

	dialog {
		margin: 0;
		background: transparent;
		border: none;
		width: 100%;
		max-width: 100%;
		height: 100%;
		max-height: 100%;
		padding: 1rem;
	}

	dialog[open] {
		display: flex;
		align-items: flex-start;
		justify-content: center;
	}

	dialog::backdrop {
		background-color: rgba(0, 0, 0, 0.6);
		-webkit-backdrop-filter: blur(4px);
		backdrop-filter: blur(4px);
	}

	.search-modal {
		width: 100%;
		max-width: 560px;
		background-color: #ffffff;
		border-radius: 16px;
		box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
		display: flex;
		flex-direction: column;
		max-height: 70vh;
		overflow: hidden;
		animation: slideIn 0.2s ease-out;
	}

	@keyframes slideIn {
		from {
			opacity: 0;
			transform: translateY(-10px) scale(0.98);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	.search-header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.875rem 1rem;
		border-bottom: 1px solid #e5e7eb;
		position: relative;
	}

	.search-icon {
		color: #9ca3af;
		flex-shrink: 0;
	}

	.search-input {
		flex: 1;
		border: none;
		outline: none;
		font-size: 1rem;
		background: transparent;
		color: #1f2937;
		font-family: inherit;
	}

	.search-input::placeholder {
		color: #9ca3af;
	}

	.search-clear {
		display: flex;
		align-items: center;
		justify-content: center;
		border: none;
		background: none;
		color: #9ca3af;
		cursor: pointer;
		padding: 0.25rem;
		border-radius: 6px;
		transition: color 0.15s, background-color 0.15s;
	}

	.search-clear:hover {
		color: #1f2937;
		background-color: #f3f4f6;
	}

	.search-shortcut-modal {
		display: flex;
		align-items: center;
		justify-content: center;
		background-color: #f3f4f6;
		padding: 0.25rem 0.5rem;
		border-radius: 6px;
	}

	.search-shortcut-modal kbd {
		font-size: 0.75rem;
		font-family: ui-monospace, SFMono-Regular, monospace;
		color: #6b7280;
	}

	.search-results {
		flex: 1;
		overflow-y: auto;
		padding: 0.5rem;
	}

	.search-loading,
	.search-empty,
	.search-error {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 3rem 1rem;
		color: #6b7280;
	}

	.spinner {
		width: 32px;
		height: 32px;
		border: 2px solid #e5e7eb;
		border-top-color: #3b82f6;
		border-radius: 50%;
		animation: spin 0.8s linear infinite;
		margin-bottom: 0.75rem;
	}

	@keyframes spin {
		to {
			transform: rotate(360deg);
		}
	}

	.search-empty p,
	.search-error p {
		font-size: 0.875rem;
		text-align: center;
	}

	.search-term {
		font-weight: 500;
		color: #1f2937;
	}

	.results-list {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.result-item {
		display: flex;
		flex-direction: column;
		padding: 0.75rem 0.875rem;
		border-radius: 8px;
		text-decoration: none;
		color: inherit;
		transition: background-color 0.15s;
	}

	.result-item:hover {
		background-color: #f9fafb;
	}

	.result-title {
		font-size: 0.9375rem;
		font-weight: 500;
		color: #1f2937;
		margin-bottom: 0.25rem;
		line-height: 1.4;
	}

	.result-excerpt {
		font-size: 0.8125rem;
		color: #6b7280;
		line-height: 1.5;
		margin-bottom: 0.25rem;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.result-path {
		font-size: 0.75rem;
		color: #9ca3af;
		font-family: ui-monospace, SFMono-Regular, monospace;
	}

	.result-item mark {
		background-color: rgba(251, 191, 36, 0.4);
		color: #92400e;
		padding: 0 2px;
		border-radius: 2px;
	}

	html.dark .search-shortcut kbd {
		background-color: var(--bg-tertiary);
	}

	html.dark dialog {
		background: transparent;
	}

	html.dark .search-modal {
		background-color: #1e293b;
	}

	html.dark .search-header {
		border-bottom-color: #374151;
	}

	html.dark .search-icon {
		color: #9ca3af;
	}

	html.dark .search-input {
		color: #f9fafb;
	}

	html.dark .search-input::placeholder {
		color: #6b7280;
	}

	html.dark .search-clear {
		color: #9ca3af;
	}

	html.dark .search-clear:hover {
		color: #f9fafb;
		background-color: #374151;
	}

	html.dark .search-shortcut-modal {
		background-color: #374151;
	}

	html.dark .search-shortcut-modal kbd {
		color: #9ca3af;
	}

	html.dark .search-loading,
	html.dark .search-empty,
	html.dark .search-error {
		color: #9ca3af;
	}

	html.dark .search-term {
		color: #f9fafb;
	}

	html.dark .spinner {
		border-color: #374151;
		border-top-color: #60a5fa;
	}

	html.dark .result-item:hover {
		background-color: #334155;
	}

	html.dark .result-title {
		color: #f9fafb;
	}

	html.dark .result-excerpt {
		color: #9ca3af;
	}

	html.dark .result-path {
		color: #6b7280;
	}

	html.dark .result-item mark {
		background-color: rgba(251, 191, 36, 0.3);
		color: #fbbf24;
	}
</style>