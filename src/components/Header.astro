---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import SearchModal from './SearchModal.astro';
---

<header>
	<nav>
		<div class="nav-left">
			<h2><a href="/">{SITE_TITLE}</a></h2>
		</div>
		
		<div class="nav-center">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/tags">Tags</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		
		<div class="nav-right">
			<SearchModal />
			<button id="theme-toggle" class="nav-btn" title="Toggle theme" aria-label="Toggle theme">
				<svg id="theme-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<script>document.write(document.documentElement.classList.contains('dark') ? '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>' : '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>')</script>
				</svg>
			</button>
		</div>
	</nav>
</header>

<script is:inline>
	(function() {
		const STORAGE_KEY = 'astro-theme';
		const themeToggle = document.getElementById('theme-toggle');
		const themeIcon = document.getElementById('theme-icon');
		
		const DARK_ICON = `<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>`;
		const LIGHT_ICON = `<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>`;

		function getSystemTheme() {
			if (typeof window !== 'undefined' && window.matchMedia) {
				return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
			}
			return 'light';
		}

		function getStoredTheme() {
			if (typeof localStorage !== 'undefined') {
				return localStorage.getItem(STORAGE_KEY);
			}
			return null;
		}

		function setTheme(theme, saveToStorage = false) {
			const html = document.documentElement;
			
			const preloadStyle = document.getElementById('theme-preload-style');
			if (preloadStyle) {
				preloadStyle.remove();
			}
			
			if (theme === 'dark') {
				html.classList.add('dark');
				html.setAttribute('data-theme', 'github-dark');
				if (themeIcon) {
					themeIcon.innerHTML = DARK_ICON;
				}
			} else {
				html.classList.remove('dark');
				html.setAttribute('data-theme', 'github-light');
				if (themeIcon) {
					themeIcon.innerHTML = LIGHT_ICON;
				}
			}

			if (saveToStorage && typeof localStorage !== 'undefined') {
				localStorage.setItem(STORAGE_KEY, theme);
			}
			
			const event = new Event('themeChange');
			document.dispatchEvent(event);
		}

		function toggleTheme() {
			const isDark = document.documentElement.classList.contains('dark');
			const newTheme = isDark ? 'light' : 'dark';
			setTheme(newTheme, true);
		}

		// Initialize theme
		function initTheme() {
			const stored = getStoredTheme();
			let theme = null;
			if (stored && stored !== 'auto') {
				theme = stored;
			} else {
				theme = getSystemTheme();
			}
			setTheme(theme, false);
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', () => {
				initTheme();
				themeToggle?.addEventListener('click', toggleTheme);
			});
		} else {
			initTheme();
			themeToggle?.addEventListener('click', toggleTheme);
		}

		// Listen for system theme changes
		if (typeof window !== 'undefined' && window.matchMedia) {
			window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
				const stored = getStoredTheme();
				if (!stored || stored === 'auto') {
					setTheme(e.matches ? 'dark' : 'light');
				}
			});
		}
	})();
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		width: 100%;
		border-bottom: 1px solid var(--border-color);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		background-color: rgba(255, 255, 255, 0.6);
		transition: background-color 0.3s ease, border-color 0.3s ease;
	}
	
	h2 {
		margin: 0;
		font-size: 1.125rem;
		font-weight: 600;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		color: var(--text-primary);
	}
	
	nav {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 64px;
		padding: 0 1rem;
		font-family: 'Inter', 'Noto Sans SC', -apple-system, BlinkMacSystemFont, sans-serif;
	}
	
	.nav-left {
		flex-shrink: 0;
	}
	
	.nav-center {
		display: flex;
		gap: 2rem;
	}
	
	.nav-right {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}
	
	.nav-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		border: none;
		background: none;
		border-radius: 0.5rem;
		color: var(--text-secondary);
		cursor: pointer;
		transition: all 0.2s ease;
	}
	
	.nav-btn:hover {
		background-color: var(--bg-secondary);
		color: var(--accent);
	}
	
	.nav-center a {
		padding: 0.5rem 0;
		color: var(--text-secondary);
		font-size: 0.875rem;
		font-weight: 700;
		text-decoration: none;
		border-bottom: 2px solid transparent;
		transition: all 0.2s ease;
	}
	
	.nav-center a:hover {
		color: var(--accent);
	}
	
	.nav-center a.active {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}

	html.dark header {
		background-color: rgba(15, 23, 42, 0.7);
	}
</style>